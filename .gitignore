# Virtual environments
.venv/
venv/
env/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.spec

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (raw & processed — often large/sensitive)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/processed_dds/*
!data/processed_dds/.gitkeep

# Model files (binary, large)
outputs/models/*
!outputs/models/.gitkeep
outputs/results/*
!outputs/results/.gitkeep
outputs/models_dds/*
!outputs/models_dds/.gitkeep
outputs/results_dds/*
!outputs/results_dds/.gitkeep

# Experiment model binaries (keep JSON/CSV metrics, drop .pkl)
experiments/**/outputs/**/*.pkl

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment variables
.env
.env.*

# Distribution
*.tar.gz
*.zip
